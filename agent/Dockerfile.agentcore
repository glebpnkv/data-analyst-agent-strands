# Container for the agent on AgentCore Runtime (hackathon build).
#
# AgentCore Runtime has a fixed contract: container listens on :8080,
# exposes POST /invocations and GET /ping. The `bedrock-agentcore` SDK's
# `BedrockAgentCoreApp` does that for us — see agent/agent.py.
#
# We deliberately reuse the repo's pyproject.toml / uv.lock rather than
# trimming dependencies for this image. It pulls more than the hackathon
# build strictly needs (chainlit, sqlalchemy, etc), but we're optimising
# for "ship the demo by Friday" not image size — same uv sync the rest
# of the repo uses, no parallel dependency story to maintain.

FROM python:3.12-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    UV_LINK_MODE=copy \
    UV_COMPILE_BYTECODE=1

COPY --from=ghcr.io/astral-sh/uv:0.5.13 /uv /uvx /usr/local/bin/

WORKDIR /app

# ca-certificates is enough — no MCP subprocess in this image (the
# hackathon build doesn't use the AWS API MCP server, and AgentCore
# Code Interpreter replaces the local sandbox).
RUN apt-get update \
 && apt-get install -y --no-install-recommends ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Project metadata first so dep installs cache across code-only changes.
COPY pyproject.toml uv.lock /app/
RUN uv sync --frozen --no-dev --no-install-project

COPY agent /app/agent

# AgentCore Runtime contract: must listen on :8080.
EXPOSE 8080

ENV PYTHONPATH=/app

# `python -m agent.agent` runs the BedrockAgentCoreApp.run() block,
# which spins up a Starlette server on :8080 with /invocations and
# /ping wired to the @entrypoint handler.
CMD ["uv", "run", "--no-dev", "--frozen", "python", "-m", "agent.agent"]
